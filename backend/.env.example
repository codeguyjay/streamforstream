# Twitch API credentials
# Get these from Twitch Developer Console -> Your App -> Client ID / Client Secret
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Frontend origin allowed by backend CORS
FRONTEND_ORIGIN=http://localhost:3000

# How often the backend re-checks the live board against Twitch
TWITCH_SWEEPER_INTERVAL_SECONDS=300

# Storage backend: "in_memory" for local/dev fallback, or "dynamodb"
STREAMING_STORE_BACKEND=in_memory

# AWS / DynamoDB settings used when STREAMING_STORE_BACKEND=dynamodb
AWS_REGION=us-east-1
DDB_ENDPOINT_URL=
DDB_STREAMER_STATE_TABLE_NAME=
DDB_VIEW_REPORTS_TABLE_NAME=
